{
  "manifest_version": 3,
  "name": "ChatGPT to Wiki Inbox",
  "version": "1.0.0",
  "description": "Sends explicitly marked ChatGPT research summaries to the local wiki inbox.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
